/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Lightsheet NIS Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Input options
    input  = null      // samplesheet CSV: sample,tile_dir[,device]
    models = null      // directory of TorchScript .pt models
    outdir = './results'

    // NIS executable options (forwarded via modules.config ext.args)
    batch_size           = 400
    chunk_depth          = 35
    cellprob_threshold   = 0.1
    filename_tag         = '_C1_'
    no_foreground_detection = true
    isotropic            = false

    // Downstream postprocessing options (coord_to_bbox -> stitch -> brain map -> coloc)
    overlap_ratio        = 0.2            // tile overlap ratio used for stitching/fusion
    map_type             = 'cell count'   // 'cell count' or 'avg volume'
    num_column           = 2              // tile-grid columns (default; overridden per brain)
    num_row              = 2              // tile-grid rows    (default; overridden per brain)
    // printf pattern of the raw-image tile sub-folders under each brain's image_dir.
    // Receives column then row as two integer args, e.g. 'UltraII[%02d x %02d]' ->
    // 'UltraII[00 x 01]'. Customize for other microscope layouts (e.g. 'tile_%d_%d').
    image_tile_pattern   = 'UltraII[%02d x %02d]'
    // printf pattern of the raw 2D slice filenames inside each tile folder, carrying the
    // z index, e.g. 'L_C1_Z%04d.ome.tif'. null = auto-derive from the files (the original
    // <prefix>_<z>_<mid>_xyz-Table Z<z>.ome.tif convention).
    slice_filename_pattern = null
    run_morphometry      = false          // run per-nucleus 3D shape morphometry (paper stage 12)
    morph_vol_min        = 1              // skip instances with volume < this
    morph_vol_max        = 0              // skip instances with volume > this (0 = no max)
    run_stitchrefine     = false          // run optional point-registration stitch refinement (README 3.5)
    ptreg_zrange         = 15             // Z window for point-registration refinement
    run_coloc            = false          // run the optional multi-channel coloc step
    coloc_gtag           = 'P4'           // growth-stage tag for coloc (P4 or P14)
    coloc_weights        = null           // optional coloc classifier checkpoint

    // Max resource options
    max_memory = '128.GB'
    max_cpus   = 16
    max_time   = '240.h'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    debug {
        process.beforeScript = 'echo $HOSTNAME'
    }
    docker {
        docker.enabled       = true
        docker.runOptions    = '--gpus all -u $(id -u):$(id -g)'
        singularity.enabled  = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--nv'
        docker.enabled         = false
    }
    test {
        params.input  = "${projectDir}/assets/samplesheet.csv"
        params.models = "${projectDir}/assets"
    }
}

manifest {
    name            = 'lightsheet-nis'
    author          = 'Ziquan Wei (@Chrisa142857)'
    description     = '3D nuclei instance segmentation for whole-brain lightsheet microscopy'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}
