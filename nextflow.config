/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Lightsheet NIS Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Input options
    input  = null      // samplesheet CSV: sample,tile_dir[,device]
    models = null      // directory of TorchScript .pt models
    outdir = './results'

    // NIS executable options (forwarded via modules.config ext.args)
    batch_size           = 400
    chunk_depth          = 35
    cellprob_threshold   = 0.1
    filename_tag         = '_C1_'
    no_foreground_detection = true
    isotropic            = false

    // Max resource options
    max_memory = '128.GB'
    max_cpus   = 16
    max_time   = '240.h'
}

includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    debug {
        process.beforeScript = 'echo $HOSTNAME'
    }
    docker {
        docker.enabled       = true
        docker.runOptions    = '--gpus all -u $(id -u):$(id -g)'
        singularity.enabled  = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.runOptions = '--nv'
        docker.enabled         = false
    }
    test {
        params.input  = "${projectDir}/assets/samplesheet.csv"
        params.models = "${projectDir}/assets"
    }
}

manifest {
    name            = 'lightsheet-nis'
    author          = 'Ziquan Wei (@Chrisa142857)'
    description     = '3D nuclei instance segmentation for whole-brain lightsheet microscopy'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.04.0'
    version         = '1.0.0'
}
