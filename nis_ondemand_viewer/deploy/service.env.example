# Copy to service.env and edit for your server. Consumed by docker-compose
# (env_file + volume interpolation) and usable as the systemd EnvironmentFile.

# --- data roots (absolute paths on the data server) ---------------------------
NIS_ROOT=/scheibel/ACMUSERS/ziquanw/Lightsheet/results
RAW_ROOT=/cajal/ACMUSERS/ziquanw/Lightsheet/image_before_stitch
STITCH_ROOT=/scheibel/ACMUSERS/ziquanw/Lightsheet/stitch_params

# --- dataset selection --------------------------------------------------------
P_TAG=P14
RAW_CHANNEL=C01

# --- resolutions (micron) -- defaults match the NIS C++ hard-coded values -----
MAP_RES=25
ORIG_RES_Z=4
ORIG_RES_X=0.75
ORIG_RES_Y=0.75
NIS_RES_Z=2.5
NIS_RES_X=0.75
NIS_RES_Y=0.75
CUBEN=5
CUBEN_Z=3

# --- grid fallback (only used when STITCH_ROOT/<brain>.xml is absent) ----------
GRID_COLS=1
GRID_ROWS=1
TILE_WIDTH=2048
TILE_HEIGHT=2048
TILE_DEPTH=2000
TILE_OVERLAP=0

# --- service ------------------------------------------------------------------
CACHE_CAPACITY=256
# Absolute origin to advertise in /zoom/info URLs. Leave empty for relative URLs
# (the frontend prepends VITE_ZOOM_API_ORIGIN itself).
PUBLIC_ORIGIN=
