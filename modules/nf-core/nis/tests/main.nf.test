nextflow_process {

    name "Test Process NIS"
    script "../main.nf"
    process "NIS"

    tag "modules"
    tag "modules_nfcore"
    tag "nis"

    // NOTE: A non-stub test requires a CUDA GPU, the GPU container image, the
    // TorchScript `.pt` models, and a small lightsheet tile. These are not yet
    // available in the shared nf-core test-data, so only a stub test is provided.
    // Replace `params.modules_testdata_base_path + ...` paths once test data exists.

    test("lightsheet - tile - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [
                    [ id:'test_brain' ],
                    file(params.modules_testdata_base_path + 'imaging/segmentation/nis/tile', checkIfExists: false)
                ]
                input[1] = file(params.modules_testdata_base_path + 'imaging/segmentation/nis/models', checkIfExists: false)
                """
            }
        }

        then {
            assert process.success
            assertAll(
                { assert snapshot(process.out).match() }
            )
        }

    }

}
