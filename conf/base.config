/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Base resource requirements
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Cap every task's request to the configured ceiling (params.max_*),
    // so requests never exceed the executor's available resources.
    resourceLimits = [
        cpus  : params.max_cpus,
        memory: params.max_memory as nextflow.util.MemoryUnit,
        time  : params.max_time   as nextflow.util.Duration
    ]

    cpus   = { 2    * task.attempt }
    memory = { 12.GB * task.attempt }
    time   = { 4.h  * task.attempt }

    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    withLabel:process_high {
        cpus   = { 8     * task.attempt }
        memory = { 64.GB * task.attempt }
        time   = { 48.h  * task.attempt }
    }

    // NIS requires a CUDA GPU; request one accelerator per task.
    withLabel:process_gpu {
        accelerator = 1
    }
}
