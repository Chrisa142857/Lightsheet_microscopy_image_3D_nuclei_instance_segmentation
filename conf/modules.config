/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    withName: 'NIS_SEGMENT' {
        // Forward NIS CLI flags from params. `meta.device` (set per-row in the
        // samplesheet) overrides --device inside the module.
        ext.args = {
            [
                "--batch_size ${params.batch_size}",
                "--chunk_depth ${params.chunk_depth}",
                "--cellprob_threshold ${params.cellprob_threshold}",
                "--filename_tag ${params.filename_tag}",
                params.no_foreground_detection ? '--no_foreground_detection' : '',
                params.isotropic                ? '--isotropic'              : ''
            ].findAll { it }.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/nis/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
