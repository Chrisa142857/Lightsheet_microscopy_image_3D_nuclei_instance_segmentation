/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Per-module configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    withName: 'NIS_SEGMENT' {
        // Output prefix = the brain tag, so every tile yields {btag}_NIScpp_results_*
        // (downstream stitch/brain-map index tiles by the UltraII[col x row]/ dir, not
        // by file name). `meta.device` overrides --device inside the module.
        ext.prefix = { meta.brain ?: meta.id }
        ext.args = {
            [
                "--batch_size ${params.batch_size}",
                "--chunk_depth ${params.chunk_depth}",
                "--cellprob_threshold ${params.cellprob_threshold}",
                "--filename_tag ${params.filename_tag}",
                params.no_foreground_detection ? '--no_foreground_detection' : '',
                params.isotropic                ? '--isotropic'              : ''
            ].findAll { it }.join(' ')
        }
        publishDir = [
            path: { "${params.outdir}/nis/${meta.brain ?: meta.id}/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_COORDTOBBOX' {
        publishDir = [
            path: { "${params.outdir}/bbox/${meta.brain}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_MORPHOMETRY' {
        publishDir = [
            path: { "${params.outdir}/morphometry/${meta.brain}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_STITCH' {
        publishDir = [
            path: { "${params.outdir}/stitch/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_STITCHREFINE' {
        publishDir = [
            path: { "${params.outdir}/stitch/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_BRAINMAP' {
        publishDir = [
            path: { "${params.outdir}/brainmap/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'CELLPHENO_COLOC' {
        publishDir = [
            path: { "${params.outdir}/coloc/${meta.id}" },
            mode: 'copy',
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
